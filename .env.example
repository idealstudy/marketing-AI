# ── Ports (change if defaults conflict) ──
DASHBOARD_PORT=34560
GATEWAY_PORT=18789

# ── Timezone ──
TZ=Asia/Seoul

# ── Authentication ──
OPENCLAW_GATEWAY_TOKEN=your-gateway-token
DASHBOARD_AUTH_TOKEN=your-dashboard-token

# ── Threads ──
THREADS_ACCESS_TOKEN=your-threads-token
THREADS_USER_ID=your-threads-user-id

# ── X (Twitter) — optional ──
# X_API_KEY=your-x-api-key
# X_API_KEY_SECRET=your-x-api-key-secret
# X_ACCESS_TOKEN=your-x-access-token
# X_ACCESS_TOKEN_SECRET=your-x-access-token-secret

# ── Instagram (Business account required) — optional ──
# INSTAGRAM_ACCESSTOKEN=your-instagram-access-token
# INSTAGRAM_USERID=your-instagram-business-user-id

# ── D-Edu Blog — 대시보드 Blog Settings에서도 입력 가능 ──
# DEDU_API_BASE_URL=https://api.d-edu.site
# DEDU_ADMIN_EMAIL=your-admin-email
# DEDU_ADMIN_PASSWORD=your-admin-password

# ── Naver Search Ad API — optional ──
# NAVER_SEARCHAD_CLIENT_ID=your-naver-searchad-client-id
# NAVER_SEARCHAD_CLIENT_SECRET=your-naver-searchad-secret
# NAVER_SEARCHAD_CUSTOMER_ID=your-naver-searchad-customer-id

# ── Image features (Cloudflare R2) — optional ──
GOOGLE_API_KEY=your-google-api-key
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=your-bucket-name
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://your-bucket.r2.dev
DASHBOARD_PUBLIC_URL=https://your-dashboard-domain.example.com
